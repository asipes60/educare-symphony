{
  "name": "educare-symphony",
  "version": "0.1.0",
  "description": "EduCare Symphony orchestration service",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "tick": "tsx src/index.ts",
    "tick:dev": "tsx watch src/index.ts",
    "validate": "tsx src/cli/validate.ts",
    "test": "node --import tsx --test 'src/**/*.test.ts'",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.1",
    "@google-cloud/secret-manager": "^5.6.0",
    "airtable": "^0.12.2",
    "dotenv": "^16.4.5",
    "googleapis": "^144.0.0",
    "js-yaml": "^4.1.0",
    "pino": "^9.5.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.9.0",
    "@typescript-eslint/eslint-plugin": "^8.14.0",
    "@typescript-eslint/parser": "^8.14.0",
    "eslint": "^9.14.0",
    "pino-pretty": "^11.3.0",
    "prettier": "^3.3.3",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
